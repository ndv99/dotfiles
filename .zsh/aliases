# dotfile management
alias dotfiles='/usr/bin/git --git-dir=$HOME/.cfg/ --work-tree=$HOME'
alias dfl='dotfiles'

# "yarn" commands
alias y="yarn"
alias ya="yarn add"
alias yad="yarn add -D"
alias yr="yarn remove"
alias yc="yarn clean"
alias ys="yarn start"
alias yys="y && ys"
alias ycs="yc && yys"
alias yd="yarn dev"
alias yyd="y && yd"
alias ycd="yc && yyd"
alias yt="yarn test"
alias yl="yarn lint"
alias ylt="yl && yt"
alias yylt="y && yl && yt"
alias yb="yarn build"
alias ycb="yc && y && yb"

# docker
alias dcu="docker compose up"
alias dcd="docker compose down"
alias dce="docker compose exec"

# "lxc" commands
alias lxcl="watch lxc list --all-projects"

# misc
alias ns="notify-send"
alias nwd="notify-when-done"

# backup to NAS
alias backup="rsync -av -e ssh /home/noodl ndv99@192.168.0.3::NetBackup/$(hostname)/home/ --exclude '.cache' --exclude 'SteamLibrary' --exclude 'Downloads' --exclude 'Video"

